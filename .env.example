# AI Synthetic Platform - Environment Variables Template
# Copy this file to .env.local and fill in the actual values for local development
# DO NOT commit actual secrets to version control

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# PostgreSQL or compatible database connection string
# Format: postgresql://username:password@host:port/database_name
# Example: postgresql://user:password@localhost:5432/ai_synthetic_db
DATABASE_URL=your_database_url

# ============================================================================
# AUTHENTICATION (NextAuth.js)
# ============================================================================
# Secret key for encrypting tokens and sessions
# Generate a secure random string: openssl rand -base64 32
NEXTAUTH_SECRET=your_secret_key

# The URL where your application is accessible
# For development: http://localhost:3000
# For production: https://yourdomain.com
NEXTAUTH_URL=http://localhost:3000

# ============================================================================
# STRIPE INTEGRATION (Billing & Payments)
# ============================================================================
# Stripe Publishable Key - used on the client side for payment forms
# Get from: https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_...

# Stripe Secret Key - used on the server side for backend operations
# KEEP THIS SECURE - never expose publicly
STRIPE_SECRET_KEY=sk_...

# ============================================================================
# AI PROVIDERS
# ============================================================================
# OpenAI API Key for GPT models and embeddings
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Anthropic Claude API Key for Claude models
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=...

# ============================================================================
# VOICE & AUDIO
# ============================================================================
# ElevenLabs API Key for text-to-speech synthesis
# Get from: https://elevenlabs.io/app/api-keys
ELEVENLABS_API_KEY=...

# ============================================================================
# ANALYTICS
# ============================================================================
# PostHog API Key for product analytics and event tracking
# Get from: https://app.posthog.com/settings/project
POSTHOG_API_KEY=...
